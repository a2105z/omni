# ===========================================
# Omni – Vercel Environment Variables
# Copy to .env.local for local dev, or add in Vercel Dashboard for production
# ===========================================

# Required for search & synthesis
OPENAI_API_KEY=sk-...

# Required for web & image search (Brave API)
BRAVE_API_KEY=...

# AI providers (at least one set per category for fallbacks)
# Query optimization & summarization
CEREBRAS_API_KEY=...
CEREBRAS_API_KEY2=...
CEREBRAS_API_KEY3=...

# Follow-up questions & session titles
GROQ_API_KEY=...
GROQ_API_KEY2=...
GROQ_API_KEY3=...

# Optional: Firecrawl for advanced scraping
# FIRECRAWL_API_KEY=fc-...

# Optional: Phase 3 backend (Python FastAPI) – enables indexed search + synthesis
# When set, /api/answer proxies to backend. When unset, legacy Brave+scrape pipeline is used.
# BACKEND_URL=https://your-backend.railway.app
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.railway.app
